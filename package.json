{
  "name": "what-to-eat",
  "description": "A desktop-friendly meal recommendation app built with Vite, React and Electron.",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "config": {
    "electron_mirror": "https://cdn.npmmirror.com/binaries/electron/",
    "electron_builder_binaries_mirror": "https://cdn.npmmirror.com/binaries/electron-builder-binaries/"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:proxy\"",
    "dev:vite": "vite",
    "dev:proxy": "nodemon --watch server --watch .env --watch .env.local --ext cjs,env,local --exec \"node server/amap-proxy.cjs\"",
    "dev:desktop": "node electron/cleanup-dev.cjs && concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:electron": "wait-on http-get://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 nodemon --watch electron --ext cjs --exec \"node electron/launch.cjs .\"",
    "clean": "node -e \"const fs = require('fs'); const path = require('path'); function rmDir(dir) { if (fs.existsSync(dir)) { fs.readdirSync(dir).forEach(file => { const curPath = path.join(dir, file); if (fs.lstatSync(curPath).isDirectory()) rmDir(curPath); else fs.unlinkSync(curPath); }); fs.rmdirSync(dir); } } rmDir('dist'); rmDir('release'); rmDir('node_modules/.vite');\"",
    "build": "tsc && vite build",
    "build:clean": "npm run clean && npm run build",
    "package": "npm run build && electron-builder",
    "package:dir": "npm run build && electron-builder --dir",
    "package:win": "npm run build && electron-builder --win nsis",
    "start:proxy": "node server/amap-proxy.cjs",
    "start:desktop": "node electron/launch.cjs .",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^38.8.6",
    "electron-builder": "^26.0.12",
    "gh-pages": "^6.1.1",
    "nodemon": "^3.1.10",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.matchprogram.whattoeat",
    "productName": "今天吃什么",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "electronDist": "node_modules/electron/dist",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
